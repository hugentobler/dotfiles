# Cloudflare WARP root certificate environment variables.
# -------------------------------------------------------
# Prerequisites (run once per machine):
#   brew install certifi && source ~/.zshrc
#   echo | cat - '/Library/Application Support/Cloudflare/installed_cert.pem' >> $(python3 -m certifi)
#
# Only symlink/copy this file to ~/.config/cloudflare-cert.env on machines
# that run Cloudflare WARP with TLS inspection.

export CERT_PATH=$(python3 -m certifi)
# Python
export REQUESTS_CA_BUNDLE=$CERT_PATH
export HTTPLIB2_CA_CERTS=$CERT_PATH
# Node.js
export NODE_EXTRA_CA_CERTS=$CERT_PATH
export SSL_CERT_FILE=$CERT_PATH
# AWS CLI (uncomment if needed)
# export AWS_CA_BUNDLE=$CERT_PATH
